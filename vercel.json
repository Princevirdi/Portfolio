{
  "version": 2,
  "buildCommand": "python manage.py collectstatic --noinput",
  "builds": [
    { "src": "api/wsgi.py", "use": "@vercel/python" },
    { "src": "staticfiles/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/(.*)", "dest": "api/wsgi.py" }
  ]
}
